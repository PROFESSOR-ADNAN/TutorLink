# Base URL of the backend API. In development, Vite proxies /api to
# http://localhost:5000 (see vite.config.js), so this can usually be left
# unset locally. In production, point this at your deployed API, e.g.
# https://api.tutorlink.com/api/v1
VITE_API_URL=/api/v1

# Stripe publishable (public) key used for the booking/payment flow.
# Get this from https://dashboard.stripe.com/apikeys
# Payments are disabled with a clear message if this is left unset.
VITE_STRIPE_PUBLIC_KEY=
