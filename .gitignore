.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Build output ──────────────────────────────────────────
dist/
build/
.next/

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────
logs/
*.log

# ── Docker ────────────────────────────────────────────────
# Docker creates these when using local volumes
.dockerignore
